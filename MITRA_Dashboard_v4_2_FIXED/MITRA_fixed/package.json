{
  "name": "mitra-backend",
  "version": "4.1.0",
  "description": "MITRA Government School AR Platform — Master Control Backend",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "migrate":   "node db/migrate.js",
    "seed":      "node db/seed.js && node db/seed_india_locations.js",
    "setup":     "npm run migrate && npm run seed",
    "lint":      "eslint routes/ db/ middleware/ --ext .js"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "compression":       "^1.7.4",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.18.2",
    "express-rate-limit":"^7.2.0",
    "express-validator": "^7.0.1",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "multer":            "^1.4.5-lts.1",
    "node-fetch":        "^2.7.0",
    "pg":                "^8.11.5",
    "uuid":              "^9.0.1",
    "xlsx":              "^0.18.5"
  },
  "devDependencies": {
    "eslint":   "^8.57.0",
    "nodemon":  "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
